{
  "name": "phentrieve-frontend",
  "version": "0.16.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --cache --cache-strategy content --cache-location .eslintcache",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write --cache --cache-strategy content \"src/**/*.{js,vue,css,scss,html}\"",
    "format:check": "prettier --check --cache --cache-strategy content \"src/**/*.{js,vue,css,scss,html}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:ci": "vitest run --no-coverage --reporter=default",
    "test:coverage": "vitest run --coverage",
    "i18n:check": "node scripts/validate-i18n.js && vue-i18n-extract --vueFiles './src/**/*.{vue,js,ts}' --languageFiles './src/locales/**/*.json'",
    "i18n:report": "vue-i18n-extract --output json --vueFiles './src/**/*.{vue,js,ts}' --languageFiles './src/locales/**/*.json' > i18n-report.json",
    "audit": "npm audit --audit-level=high",
    "audit:prod": "npm audit --omit=dev --audit-level=critical",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "@berntpopp/phenopackets-js": "^1.0.2",
    "axios": "^1.18.1",
    "google-protobuf": "^4.0.2",
    "libphonenumber-js": "^1.13.7",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.5.35",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "vue-virtual-scroller": "^3.0.4",
    "vuetify": "^3.12.8"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fullhuman/postcss-purgecss": "^5.0.0",
    "@mdi/font": "^7.3.67",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.0.9",
    "@vue/test-utils": "^2.4.11",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "postcss": "^8.5.16",
    "prettier": "^3.9.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "terser": "^5.48.0",
    "vite": "^8.0.16",
    "vite-plugin-compression": "^0.5.1",
    "vitest": "^4.0.9",
    "vue-eslint-parser": "^10.4.1",
    "vue-i18n-extract": "^2.0.7"
  }
}
