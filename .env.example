# LOCAL DEVELOPMENT .env settings (typically gitignored)
# These would be used if running phentrieve CLI directly on host

# Uncomment and set these paths for local development
# PHENTRIEVE_DATA_ROOT_DIR=./data_local_dev  # Example path relative to project root
# LOG_LEVEL=DEBUG

# Specific subdirectory overrides (optional)
# PHENTRIEVE_DATA_DIR=./data_local_dev/hpo_core_data  # For HPO source files
# PHENTRIEVE_INDEX_DIR=./data_local_dev/indexes       # For ChromaDB indexes
# PHENTRIEVE_RESULTS_DIR=./data_local_dev/results     # For benchmark results

# You can also set absolute paths if needed
# PHENTRIEVE_DATA_ROOT_DIR=/path/to/your/data

# API quota and proxy settings
PHENTRIEVE_ENV=development
PHENTRIEVE_TRUSTED_PROXY_CIDRS=172.16.0.0/12,127.0.0.1/32
PHENTRIEVE_LLM_DAILY_LIMIT=3
PHENTRIEVE_LLM_QUOTA_DB_PATH=../data/app/llm_quota.db

# -----------------------------------------------------------------------------
# Accounts / authentication (optional feature)
# -----------------------------------------------------------------------------
# Auth is OFF by default. With it off, the API behaves exactly as before
# (anonymous, IP-keyed quota). Turn it on locally to test register/login and
# the higher full-text quota for verified users.
PHENTRIEVE_AUTH_ENABLED=false
# REQUIRED when auth is enabled. Generate one, e.g.:  openssl rand -hex 32
PHENTRIEVE_AUTH_JWT_SECRET=
PHENTRIEVE_AUTH_DB_PATH=../data/app/users.db
# Token lifetimes (seconds): access 30 min, refresh 14 days.
PHENTRIEVE_AUTH_ACCESS_TTL_SECONDS=1800
PHENTRIEVE_AUTH_REFRESH_TTL_SECONDS=1209600
# Set to false for local HTTP testing; MUST be true in production (HTTPS).
PHENTRIEVE_AUTH_COOKIE_SECURE=false
# lax for same-site; use "none" (with Secure) for cross-site frontend/API.
PHENTRIEVE_AUTH_COOKIE_SAMESITE=lax
PHENTRIEVE_AUTH_MAX_FAILED_ATTEMPTS=5
PHENTRIEVE_AUTH_LOCKOUT_SECONDS=900

# Verified, logged-in users get this higher daily full-text (LLM) quota.
PHENTRIEVE_LLM_AUTHENTICATED_DAILY_LIMIT=10
# Quota enforcement: "" = enforce only in production; "true"/"false" to force.
# Set to "true" locally to actually exercise the quota.
PHENTRIEVE_LLM_QUOTA_ENFORCE=

# -----------------------------------------------------------------------------
# Email delivery (used for verification + password reset)
# -----------------------------------------------------------------------------
# "console" logs the verify/reset link (no SMTP needed) - ideal for local dev.
# "smtp" sends real email via the SMTP settings below (production).
PHENTRIEVE_EMAIL_BACKEND=console
PHENTRIEVE_EMAIL_FROM=noreply@phentrieve.org
# Public base URL used to build the links in emails (frontend origin).
PHENTRIEVE_PUBLIC_BASE_URL=http://localhost:5734
# SMTP settings (only needed when PHENTRIEVE_EMAIL_BACKEND=smtp)
PHENTRIEVE_SMTP_HOST=
PHENTRIEVE_SMTP_PORT=587
PHENTRIEVE_SMTP_USERNAME=
PHENTRIEVE_SMTP_PASSWORD=
# starttls (default) | ssl | none
PHENTRIEVE_SMTP_TLS=starttls
